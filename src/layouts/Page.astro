---
import Navbar from "@components/Navbar.astro";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Astro description" />
    <meta name="viewport" content="width=device-width" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preload" href="/index.css" as="style" />
    <link rel="stylesheet" href="/index.css" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="m-0">
    <Navbar />
    <main style="margin-top: var(--navbar-height);">
      <slot />
    </main>
    <footer>
      <div>
        <div>
          <p class="text-secondary semibold pb-4">Resources</p>
          <a href="/attribution">Attribution</a>
        </div>
        <div>
          <p class="text-secondary semibold pb-5">Links</p>
          <a
            target="_blank"
            href="https://www.linkedin.com/in/adam-smith-9728511ba/">LinkedIn</a
          >
          <a target="_blank" href="https://github.com/ADSmith-0">Github</a>
        </div>
      </div>
    </footer>
  </body>
</html>

<style>
  footer > div {
    display: inline-grid;
    grid-template-columns: repeat(2, auto);
    gap: var(--spacing-10);

    & a {
      display: block;
      padding-top: var(--spacing-3);
    }
  }
</style>
